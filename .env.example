# Kopirajte ovaj fajl u ".env" i podesite vrednosti.

# Tajni ključ za sesije (OBAVEZNO promeniti u produkciji)
SECRET_KEY=promeni-me-u-nasumican-string

# Server
HOST=0.0.0.0
PORT=8000
THREADS=4

# Valuta prikazana u aplikaciji
CURRENCY=RSD

# --- SMTP (za slanje žurnala na e-mail) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=servis@example.com
SMTP_TLS=true
# Zbirni (overall) žurnal se šalje administratorima; ova adresa je dodatni primalac
ADMIN_EMAIL=

# Automatske radnje (žurnali, podsetnik za sutra u 21h, noćna rezervna kopija)
# se sada UKLJUČUJU U APLIKACIJI: Moderator → ✉️ E-mail (globalno) →
# „Automatske radnje uključene“. Env promenljiva ENABLE_SCHEDULER se više ne
# koristi.

# --- Bezbednost / hardening ---
# Uključite kada servirate preko HTTPS (kolačići samo preko HTTPS):
SECURE_COOKIES=false
# Uključite kada je iza reverse proxija (nginx) da bi se čitali X-Forwarded-* zaglavlja:
TRUST_PROXY=false
# Zaključavanje prijave posle previše neuspešnih pokušaja:
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_MINUTES=10
# Trajanje sesije (sati):
SESSION_HOURS=12

# --- Rezervne kopije ---
# Koliko poslednjih kopija čuvati:
BACKUP_KEEP=14

# Putanja do baze (podrazumevano SQLite u instance/carservice.db)
# DATABASE_URL=sqlite:////home/pi/carservice/instance/carservice.db
